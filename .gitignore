# ==========================================
# 1. SECURITY SENSITIVE FILES (CRITICAL)
# ==========================================
# NEVER upload your master private keys or API configs! [12]
config/firebase_creds.json
.streamlit/secrets.toml

# ==========================================
# 2. LOCAL DATABASES & LOGS
# ==========================================
# Ignore the local Chroma vector database files (but keep the folder empty on GitHub)
chroma_db/*
!chroma_db/.gitkeep

# Ignore security and system log files
*.log
admin_secure.log

# ==========================================
# 3. PYTHON SYSTEM FILES
# ==========================================
# Ignore your huge virtual environment folder
.venv/
venv/
env/

# Ignore compiled python bytecode
__pycache__/
*.pyc
*.pyo
*.pyd

# ==========================================
# 4. OS SPECIFIC FILES
# ==========================================
.DS_Store
Thumbs.db